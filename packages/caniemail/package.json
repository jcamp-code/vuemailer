{
  "name": "@vuemailer/caniemail",
  "version": "1.0.0",
  "description": "Can I Email compatibility linting for HTML emails — lintHtml(html) over the full caniemail.json dataset.",
  "keywords": [
    "caniemail",
    "compatibility",
    "email",
    "html",
    "lint"
  ],
  "homepage": "https://github.com/jcamp-code/vuemailer/tree/main/packages/caniemail#readme",
  "bugs": "https://github.com/jcamp-code/vuemailer/issues",
  "license": "MIT",
  "author": "John Campion Jr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcamp-code/vuemailer.git",
    "directory": "packages/caniemail"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
