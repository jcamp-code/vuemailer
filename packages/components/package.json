{
  "name": "vuemailer",
  "version": "1.0.0",
  "description": "Build and send emails with Vue",
  "keywords": [
    "components",
    "email",
    "html-email",
    "vue"
  ],
  "homepage": "https://github.com/jcamp-code/vuemailer#readme",
  "bugs": "https://github.com/jcamp-code/vuemailer/issues",
  "license": "MIT",
  "author": "John Campion Jr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcamp-code/vuemailer.git",
    "directory": "packages/components"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./code-block": {
      "import": {
        "types": "./dist/code-block.d.ts",
        "default": "./dist/code-block.js"
      },
      "require": {
        "types": "./dist/code-block.d.cts",
        "default": "./dist/code-block.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vuemailer/render": "workspace:*",
    "css-tree": "catalog:",
    "marked": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@types/css-tree": "catalog:",
    "@types/prismjs": "catalog:",
    "prismjs": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "prismjs": "^1.30.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "prismjs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
